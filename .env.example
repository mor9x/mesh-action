DATABASE_URL=postgresql://admin:admin@127.0.0.1:5432/admin
DATABASE_POOL_MAX=8

# Server-only Sui runtime configuration.
# Preferred format: a Sui bech32 private key exported as suiprivkey...
SUIMESH_SUI_PRIVATE_KEY=suiprivkey_REPLACE_ME
SUIMESH_SUI_ADDRESS=0x_REPLACE_WITH_SIGNER_ADDRESS
SUIMESH_SUI_NETWORK=testnet
SUIMESH_PROTOCOL_MODE=canonical

# Optional RPC override. Defaults to the official fullnode URL for SUIMESH_SUI_NETWORK.
# SUIMESH_SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Public SuiMesh testnet relay and trace package.
# The trace registry must be owned by the MeshAction runtime signer above.
SUIMESH_RELAYER_URL=https://relay.suimesh.link
SUIMESH_TRACE_PACKAGE_ID=0x038caadb65def30619e6ec762715ea6ca232ac1195bc077086bc9a6b7e11bb80
SUIMESH_TRACE_REGISTRY_ID=0x_REPLACE_WITH_MESHACTION_OWNED_TRACE_REGISTRY

# Optional compatibility fallback for a base64 Sui CLI keystore entry.
# Use this instead of SUIMESH_SUI_PRIVATE_KEY only when you cannot export suiprivkey.
# SUIMESH_SUI_KEYSTORE_ENTRY=REPLACE_ME

# Optional executor address assertion. If set, it must match the signer address.
# SUIMESH_SUI_EXECUTOR_ADDRESS=0x_REPLACE_WITH_SIGNER_ADDRESS

# Walrus archive storage. Enabled by default for execution archives.
# SUIMESH_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
# SUIMESH_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
# SUIMESH_WALRUS_EPOCHS=5
# SUIMESH_WALRUS_DISABLED=false

# Seal archive encryption. Default uses public testnet key-server configs.
# SUIMESH_SEAL_PACKAGE_ID=0xdeb6325f80800c0f58d99d28b06a65f4b02adccc3275bd375e144e000bfc6bdd
# SUIMESH_SEAL_SERVER_CONFIGS=[{"objectId":"0x73d05d62c18d9374e3ea529e8e0ed6161da1a141a94d3f76ae3fe4e99356db75","weight":1},{"objectId":"0xf5d14a81a982144ae441cd7d64b09027f116a468bd36e7eca494f750591623c8","weight":1}]
# SUIMESH_SEAL_THRESHOLD=2
# SUIMESH_SEAL_VERIFY_KEY_SERVERS=true
# SUIMESH_SEAL_TIMEOUT_MS=10000

# Development fallback only. Do not use this for real archive verification demos.
# SUIMESH_SEAL_MODE=local
# SUIMESH_LOCAL_ARCHIVE_KEY=replace-with-random-local-secret

# BYO agent request timeout and registration signature freshness window.
# SUIMESH_BYO_AGENT_TIMEOUT_MS=10000
# SUIMESH_AGENT_SIGNATURE_MAX_AGE_MS=600000

# Local BYO agent demos only. Keep disabled for production.
# SUIMESH_ALLOW_INSECURE_BYO_HTTP=false
# SUIMESH_ALLOW_LOCAL_BYO_ENDPOINTS=false

# Hosted agent runtime. Leave disabled to use deterministic proposals/audits.
# MESHACTION_LLM_AGENTS=false
# MESHACTION_LLM_API_KEY=
# MESHACTION_LLM_MODEL=gpt-4.1-mini
# MESHACTION_LLM_BASE_URL=https://api.openai.com/v1

# Optional API throttles for wallet auth and BYO registration.
# MESHACTION_AUTH_CHALLENGE_LIMIT=5
# MESHACTION_AUTH_CHALLENGE_WINDOW_MS=300000
# MESHACTION_AUTH_SESSION_LIMIT=10
# MESHACTION_AUTH_SESSION_WINDOW_MS=300000
# MESHACTION_AGENT_REGISTRATION_LIMIT=8
# MESHACTION_AGENT_REGISTRATION_WINDOW_MS=600000
